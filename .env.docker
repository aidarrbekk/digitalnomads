# Docker Environment Configuration Template
# Copy to .env.docker and fill in actual values before running docker-compose

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration (PostgreSQL in Docker)
DATABASE_URL=postgresql://medical_user:medical_password@db:5432/medical_qa

# Email Configuration (Gmail SMTP)
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Groq API Configuration (for AI assistant)
GROQ_API_KEY=your-groq-api-key

# Optional: Ollama Configuration (for local LLM alternative)
# OLLAMA_API_URL=http://ollama:11434
